# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# `development` or `production`. Production hides the interactive docs.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Hard cap on extracted CV characters sent to the model.
MAX_CV_CHARS=20000

# Optional shared secret required in the `X-Internal-Token` header. Must match the
# gateway's INTERNAL_API_KEY. Leave empty to accept any caller (local dev).
INTERNAL_API_KEY=

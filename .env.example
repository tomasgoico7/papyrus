# ─────────────────────────────────────────────────────────────────────────────
# Papyrus — environment configuration for the Docker Compose stack.
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API. The gateway reuses NEXT_PUBLIC_SUPABASE_URL to derive
# the JWKS endpoint and verify the ES256/RS256 signature of access tokens, so no
# JWT secret is needed.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Google Gemini ────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── Frontend → Gateway ───────────────────────────────────────────────────────
# Public base URL the browser uses to reach the gateway.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# ── Gateway ──────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:3000
# Per-user request budget for POST /analyze.
RATE_LIMIT_RPM=20
# Maximum accepted CV upload size, in megabytes.
MAX_UPLOAD_MB=5
# Upstream timeout for a single analysis call.
REQUEST_TIMEOUT_SECONDS=60

# ── AI service ───────────────────────────────────────────────────────────────
# Hard cap on extracted CV characters sent to the model (cost/latency guard).
MAX_CV_CHARS=20000
LOG_LEVEL=INFO

# ── Shared ───────────────────────────────────────────────────────────────────
# `development` enables verbose logging and relaxed error envelopes.
ENVIRONMENT=development

# Optional shared secret. When set, the AI service only accepts requests carrying
# this token in `X-Internal-Token`, and the gateway sends it — so the AI service
# can't be called directly, bypassing auth and rate limiting. Leave empty to skip
# the check (e.g. local dev). Set the SAME value on the gateway and the AI service.
INTERNAL_API_KEY=

# Port the gateway listens on.
PORT=8080

# `development` or `production`. Production switches Gin into release mode.
ENVIRONMENT=development

# Base URL of the Python AI service.
AI_SERVICE_URL=http://localhost:8000

# Supabase project URL. The gateway derives the JWKS endpoint from it
# (<url>/auth/v1/.well-known/jwks.json) to verify the ES256/RS256 signature of
# incoming access tokens — no shared secret required.
SUPABASE_URL=https://your-project-ref.supabase.co

# Comma-separated CORS allow list.
ALLOWED_ORIGINS=http://localhost:3000

# Per-user request budget for POST /analyze.
RATE_LIMIT_RPM=20

# Maximum accepted CV upload size, in megabytes.
MAX_UPLOAD_MB=5

# Upstream timeout for a single analysis call, in seconds.
REQUEST_TIMEOUT_SECONDS=60
